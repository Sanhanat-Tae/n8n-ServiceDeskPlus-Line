      "parameters": {
        "jsCode": "const message = $json.body.events[0].message.text.toLowerCase(); // ดึงข้อความจาก Webhook\n\nlet result = {};\n\n// ตรวจสอบว่าเป็นคำสั่งเช็คหรือแจ้งงาน\nif (message.includes('check') || message.includes('เช็ค') || message.includes('ติดตามงาน')) {\n    result.command = 'check'; // ถ้าเป็นเช็คงาน ให้ส่งไปที่ node การเช็คงาน\n} else if (message.includes('create') || message.includes('แจ้งงาน')|| message.includes('แจ้งปัญหา')) {\n    result.command = 'create'; // ถ้าเป็นการแจ้งงาน ให้ส่งไปที่ node การแจ้งงาน\n} else {\n    result.command = 'unknown'; // ถ้าไม่ตรงกับเงื่อนไขให้แยกเป็น unknown\n}\n\nreturn [{ json: result }];"
      },
