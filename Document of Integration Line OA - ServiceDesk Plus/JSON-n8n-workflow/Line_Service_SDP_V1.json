    {
      "parameters": {
        "jsCode": "const message = $('Webhook').first().json.body.events[0].message.text; // ดึงข้อความจาก Webhook\n\nlet result = {\n  requester: '',\n  subject: '',\n  description: ''\n};\n\n// ตรวจสอบว่ามีคำว่า \"create\" ในข้อความ\nif (message.toLowerCase().includes('create')) {\n  // ใช้ RegEx ที่สามารถแยกข้อมูลได้ถูกต้องจากข้อความ โดยรองรับทั้งช่องว่างและ newline\n  const requesterMatch = message.match(/requester:\\s*([^\\n]*)/i);  // ตรวจสอบ requester\n  const subjectMatch = message.match(/subject:\\s*([^\\n]*)/i);      // ตรวจสอบ subject\n  const descriptionMatch = message.match(/description:\\s*([^\\n]*)/i); // ตรวจสอบ description\n  \n  // แยกข้อมูลจากข้อความ\n  if (requesterMatch && requesterMatch[1]) {\n    result.requester = requesterMatch[1].trim();  // แยก requester\n  }\n\n  if (subjectMatch && subjectMatch[1]) {\n    result.subject = subjectMatch[1].trim();  // แยก subject\n  }\n\n  if (descriptionMatch && descriptionMatch[1]) {\n    result.description = descriptionMatch[1].trim();  // แยก description\n  }\n}\n\nreturn [{ json: result }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        704,
        80
      ],
